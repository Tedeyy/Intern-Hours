Create database intern_hours_db;
use intern_hours_db;

CREATE TABLE IF NOT EXISTS users (
  id int AUTO_INCREMENT PRIMARY KEY,
  google_id text,
  google_refresh_token text NOT NULL,
  google_access_token text NOT NULL,
  name varchar(255),
  email varchar(255),
  password varchar(255),
  role enum('Intern', 'Admin') NOT NULL,
  created_at datetime DEFAULT current_timestamp(),
  updated_at datetime DEFAULT current_timestamp() ON UPDATE current_timestamp()
);

CREATE TABLE IF NOT EXISTS hours (
  hours_id int AUTO_INCREMENT PRIMARY KEY,
  user_id int NOT NULL,
  date date NOT NULL,
  hours decimal(5,2) NOT NULL,
  created_at timestamp NOT NULL DEFAULT current_timestamp()

  FOREIGN KEY (user_id) REFERENCES users (user_id)
);

CREATE TABLE IF NOT EXISTS absences (
  absences_id int AUTO_INCREMENT PRIMARY KEY,
  user_id int NOT NULL,
  date date NOT NULL,
  reason text,
  approved_by int,
  created_at datetime DEFAULT current_timestamp(),
  updated_at datetime DEFAULT current_timestamp() ON UPDATE current_timestamp(),

  FOREIGN KEY (user_id) REFERENCES users (user_id),
  FOREIGn KEY (approved_by) REFERENCES users (user_id)
)

CREATE TABLE IF NOT EXISTS accomplishment (
  accomplishment_id int AUTO_INCREMENT PRIMARY KEY,
  user_id int NOT NULL,
  date_from date NOT NULL,
  date_to date NOT NULL,
  accomplishment text,
  created_at datetime DEFAULT current_timestamp(),
  updated_at datetime DEFAULT current_timestamp() ON UPDATE current_timestamp(),
  
  FOREIGN KEY (user_id) REFERENCES users (user_id)
);